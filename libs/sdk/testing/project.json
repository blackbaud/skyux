{
  "name": "testing",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/sdk/testing/src",
  "prefix": "sky",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/libs/sdk/testing"],
      "options": {
        "project": "libs/sdk/testing/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/sdk/testing/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/sdk/testing/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@angular-devkit/build-angular:karma",
      "options": {
        "tsConfig": "libs/sdk/testing/tsconfig.spec.json",
        "karmaConfig": "libs/sdk/testing/karma.conf.js",
        "styles": [
          "libs/components/theme/src/lib/styles/sky.scss",
          "libs/components/theme/src/lib/styles/themes/modern/styles.scss"
        ],
        "codeCoverage": true,
        "codeCoverageExclude": ["**/fixtures/**"],
        "polyfills": ["zone.js", "zone.js/testing"],
        "inlineStyleLanguage": "scss",
        "stylePreprocessorOptions": {
          "includePaths": ["{workspaceRoot}"]
        }
      },
      "configurations": {
        "ci": {
          "browsers": "ChromeHeadlessNoSandbox",
          "codeCoverage": true,
          "progress": false,
          "sourceMap": true,
          "watch": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "{projectRoot}/src/**/*.ts",
          "{projectRoot}/src/**/*.html"
        ]
      }
    },
    "postbuild": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc --project libs/sdk/testing/tsconfig.schematics.json",
          "cp libs/sdk/testing/collection.json dist/libs/sdk/testing/collection.json",
          "cp libs/sdk/testing/schematics/ng-add/schema.json dist/libs/sdk/testing/schematics/ng-add/schema.json"
        ],
        "parallel": false
      }
    },
    "posttest": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/sdk/testing/schematics"],
      "options": {
        "jestConfig": "libs/sdk/testing/jest.config.ts",
        "codeCoverage": true,
        "coverageReporters": ["html", "text"]
      }
    }
  },
  "tags": ["sdk", "npm"]
}
